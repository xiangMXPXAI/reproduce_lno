{
  "data": {
    "name": "Darcy",
    "train_batch_size": 4,
    "val_batch_size": 4
  },
  "model": {
    "name": "LNO",
    "n_block": 4,
    "n_mode": 256,
    "n_dim": 128,
    "n_head": 8,
    "n_layer": 2,
    "attn": "Attention_Vanilla",
    "act": "GELU"
  },
  "loss": {
    "name": "rL2"
  },
  "optimizer": {
    "name": "AdamW",
    "lr": 0.001,
    "weight_decay": 5e-05,
    "beta0": 0.9,
    "beta1": 0.99
  },
  "scheduler": {
    "name": "OneCycle",
    "div_factor": 10000.0,
    "final_div_factor": 10000.0,
    "pct_start": 0.2
  },
  "train": {
    "epoch": 500,
    "log_print_interval_epoch": 1,
    "model_save_interval_epoch": 50,
    "grad_clip": 1000.0
  }
}